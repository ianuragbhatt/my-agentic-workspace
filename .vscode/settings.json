{
  // ─── Workbench ────────────────────────────────────────────────────────────
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "material-icon-theme",

  // ─── Editor ───────────────────────────────────────────────────────────────
  "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, Consolas, monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 20,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,

  // ─── Terminal ─────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontFamily": "JetBrains Mono, Menlo, Monaco, Consolas, monospace",
  "terminal.integrated.fontSize": 13,

  // ─── Chat ─────────────────────────────────────────────────────────────────
  "chat.editor.fontFamily": "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
  "chat.editor.fontSize": 14,
  "chat.viewSessions.orientation": "stacked",

  // ─── Files ────────────────────────────────────────────────────────────────
  "files.autoSave": "afterDelay",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ─── Explorer ─────────────────────────────────────────────────────────────
  "explorer.confirmDelete": false,

  // ─── Git ──────────────────────────────────────────────────────────────────
  "git.confirmSync": false,

  // ─── Python ───────────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],

  // ─── Jupyter ──────────────────────────────────────────────────────────────
  "jupyter.askForKernelRestart": false,
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "jupyter.interactiveWindow.mode": "perFile",
  "jupyter.enableScrollingForCellOutputs": true,

  // ─── Extensions ───────────────────────────────────────────────────────────
  "oaicopilot.baseUrl": "https://modelstudio.dct.gov.ae",
